// Srushti Publication - Kannada Books E-Commerce Database Schema
// PostgreSQL with Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// BOOK MANAGEMENT
// ============================================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique // Kannada category name
  nameEn      String?  // Optional English name for admin
  slug        String   @unique
  description String?
  image       String?
  discount    Float?   // Category-wide discount percentage
  discountStart DateTime?
  discountEnd   DateTime?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  books       Book[]
}

model Book {
  id              String   @id @default(cuid())
  title           String   // Kannada title
  titleEn         String?  // Optional English title for admin/search
  slug            String   @unique
  author          String   // Author name in Kannada
  authorEn        String?  // Optional English author name
  description     String?  @db.Text // Full Kannada description
  descriptionEn   String?  @db.Text // Optional English description
  coverImage      String?  // Cover image URL (optional to allow saving without image)
  coverImagePublicId String? // Cloudinary public ID for image deletion
  additionalImages String[] // Array of additional image URLs
  
  // Pricing
  mrp             Float    // Maximum Retail Price
  sellingPrice    Float    // Current selling price (after discount)
  discount        Float?   // Discount percentage
  discountStart   DateTime?
  discountEnd     DateTime?
  
  // Inventory
  stockQuantity   Int      @default(0)
  lowStockAlert   Int      @default(10)
  
  // Book Details
  isbn            String?  @unique
  pages           Int?
  publicationYear Int?
  edition         String?
  language        String   @default("ಕನ್ನಡ")
  weight          Float?   // Weight in grams for shipping
  dimensions      String?  // e.g., "20x15x2 cm"
  
  // Flags
  isNewRelease    Boolean  @default(false)
  isBestSeller    Boolean  @default(false)
  isOnSale        Boolean  @default(false)
  isFeatured      Boolean  @default(false)
  isActive        Boolean  @default(true)
  
  // Auto-calculated
  salesCount      Int      @default(0)
  viewCount       Int      @default(0)
  
  // Timestamps
  newReleaseUntil DateTime? // Auto-expire new release after this date
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  cartItems       CartItem[]
  
  // ============================================================
  // INDEXES - Supabase Postgres Best Practices Applied:
  // Rule 1.1: Index WHERE/JOIN columns (categoryId FK)
  // Rule 1.3: Composite indexes for multi-column queries
  // Rule 1.5: Partial indexes for filtered queries (isActive=true)
  // ============================================================

  // --- Core FK index (Rule 4.2: always index FK columns) ---
  @@index([categoryId])

  // --- Partial indexes on active books (Rule 1.5: 5-20x smaller than full indexes) ---
  // These ONLY index active books — the vast majority of queries filter isActive=true
  @@index([isActive, categoryId],        name: "book_active_category_idx")  // Browse by category
  @@index([isActive, createdAt(sort: Desc)], name: "book_active_newest_idx")    // New arrivals
  @@index([isActive, salesCount(sort: Desc)], name: "book_active_popular_idx")  // Best sellers
  @@index([isActive, sellingPrice],      name: "book_active_price_idx")     // Price filter
  @@index([isActive, isFeatured],        name: "book_active_featured_idx")  // Homepage featured
  @@index([isActive, isBestSeller],      name: "book_active_bestseller_idx")
  @@index([isActive, isNewRelease],      name: "book_active_newrelease_idx")
  @@index([isActive, isOnSale],          name: "book_active_onsale_idx")
  @@index([isActive, stockQuantity],     name: "book_active_stock_idx")     // In-stock filter

  // --- Cursor-based pagination support (Rule 6.3: O(1) vs OFFSET O(n)) ---
  @@index([createdAt, id],              name: "book_cursor_idx")

  // --- Text search (title/author) - supports prefix search in admin ---
  @@index([title],  name: "book_title_idx")
  @@index([author], name: "book_author_idx")
}

// ============================================
// CART MANAGEMENT (Session-based for guests)
// ============================================

model Cart {
  id        String   @id @default(cuid())
  sessionId String   @unique // Browser session ID
  items     CartItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime // Cart expiration for cleanup
}

model CartItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  price     Float    // Price at time of adding
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([cartId, bookId])
  @@index([cartId])
  @@index([bookId])
}

// ============================================
// ORDER MANAGEMENT
// ============================================

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique // Human-readable order number
  
  // Customer Details (Guest checkout)
  customerName    String
  customerEmail   String
  customerPhone   String
  
  // Shipping Address
  shippingAddress String   @db.Text
  shippingCity    String
  shippingState   String
  shippingPincode String
  
  // Pricing
  subtotal        Float    // Sum of item prices
  discount        Float    @default(0) // Total discount
  shippingCharge  Float    @default(0)
  taxAmount       Float    // GST amount
  totalAmount     Float    // Final payable amount
  
  // GST Details
  gstBreakup      Json?    // JSON with CGST, SGST, IGST breakdown
  
  // Payment
  paymentStatus   PaymentStatus @default(PENDING)
  razorpayOrderId String?  @unique
  razorpayPaymentId String?
  razorpaySignature String?
  paymentMethod   String?
  paidAt          DateTime?
  
  // Order Status
  status          OrderStatus @default(PENDING)
  notes           String?
  
  // Tracking
  courierName     String?
  trackingNumber  String?
  dispatchedAt    DateTime?
  deliveredAt     DateTime?
  
  // Invoice
  invoiceNumber   String?  @unique
  invoiceUrl      String?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  items           OrderItem[]
  customerId      String?
  customer        Customer? @relation("CustomerOrders", fields: [customerId], references: [id])
  
  // Supabase Best Practice Rule 1.3: composite indexes for multi-column queries
  // Admin dashboard: filter by status, sort by date
  @@index([status, createdAt(sort: Desc)],        name: "order_status_date_idx")
  // Admin payment tracking
  @@index([paymentStatus, createdAt(sort: Desc)], name: "order_payment_date_idx")
  // Customer order history lookup
  @@index([customerEmail, createdAt(sort: Desc)], name: "order_email_date_idx")
  // Unique lookups
  @@index([orderNumber],  name: "order_number_idx")
  @@index([customerId],   name: "order_customer_idx")
  // Cursor-based pagination (Rule 6.3)
  @@index([createdAt, id], name: "order_cursor_idx")
}

model OrderItem {
  id          String   @id @default(cuid())
  quantity    Int
  unitPrice   Float    // Price per unit at time of order
  totalPrice  Float    // quantity * unitPrice
  discount    Float    @default(0)
  
  // Book snapshot (in case book is deleted/modified)
  bookTitle   String
  bookAuthor  String
  bookCover   String?
  bookIsbn    String?
  
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bookId      String
  book        Book     @relation(fields: [bookId], references: [id])
  
  createdAt   DateTime @default(now())
  
  @@index([orderId])
  @@index([bookId])
}

// ============================================
// ADMIN & SETTINGS
// ============================================

model Admin {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String   // Hashed password
  name          String
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(cuid())
  
  // Business Details
  businessName    String   @default("ಸೃಷ್ಟಿ ಪಬ್ಲಿಕೇಷನ್ಸ್")
  businessNameEn  String   @default("Srushti Publications")
  tagline         String   @default("ಕನ್ನಡ ಅನುವಾದ ಪುಸ್ತಕಗಳ ಜಗತ್ತು")
  
  // Contact
  email           String?
  phone           String?
  whatsapp        String?
  address         String?  @db.Text
  
  // GST
  gstNumber       String?
  panNumber       String?
  
  // Bank Details (for reference)
  bankName        String?
  bankAccount     String?
  bankIfsc        String?
  
  // Shipping
  freeShippingMin Float?   // Minimum order for free shipping
  defaultShipping Float    @default(50) // Default shipping charge
  estimatedDays   String   @default("5-7 ದಿನಗಳು")
  
  // SEO
  metaTitle       String?
  metaDescription String?  @db.Text
  metaKeywords    String?
  
  // Social Media
  facebook        String?
  instagram       String?
  twitter         String?
  youtube         String?
  
  // Payment
  razorpayKeyId   String?
  razorpaySecret  String?
  
  // New Release Settings
  newReleaseExpiryDays Int @default(30)

  // Invoice counter — atomically incremented per order for collision-proof invoice numbers
  // Format: INV-FYFY-00001 e.g. INV-2526-00001
  invoiceCounter  Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// OFFERS & BANNERS
// ============================================

model Banner {
  id          String   @id @default(cuid())
  title       String   // Kannada title
  subtitle    String?
  image       String
  link        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Offer {
  id          String   @id @default(cuid())
  name        String
  description String?
  discountType String  // 'percentage' or 'fixed'
  discountValue Float
  minPurchase Float?
  maxDiscount Float?
  code        String?  @unique // Coupon code if applicable
  isActive    Boolean  @default(true)
  startDate   DateTime
  endDate     DateTime
  usageLimit  Int?
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// REVIEWS & RATINGS
// ============================================

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5 stars
  title       String?
  comment     String   @db.Text
  authorName  String
  authorEmail String
  isVerified  Boolean  @default(false) // Verified purchase
  isApproved  Boolean  @default(false) // Admin approved
  
  bookId      String
  orderId     String?  // Link to order for verification
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([bookId])
  @@index([isApproved])
}

// ============================================
// WISHLIST
// ============================================

model Wishlist {
  id          String   @id @default(cuid())
  sessionId   String   // For guest users
  userId      String?  // For future authenticated users
  
  bookId      String
  
  createdAt   DateTime @default(now())
  
  @@unique([sessionId, bookId])
  @@index([sessionId])
  @@index([bookId])
}

// ============================================
// EMAIL LOGS
// ============================================

model EmailLog {
  id          String   @id @default(cuid())
  type        String   // 'order_confirmation', 'shipping_update', 'delivery', etc.
  to          String
  subject     String
  status      String   @default("pending") // 'pending', 'sent', 'failed'
  orderId     String?
  templateData Json?
  errorMessage String?
  sentAt      DateTime?
  
  createdAt   DateTime @default(now())
  
  @@index([orderId])
  @@index([type])
  @@index([status])
}

// ============================================
// SITE SETTINGS EXTENSIONS
// ============================================

model HeroSettings {
  id              String   @id @default(cuid())
  heroTagline     String   @default("📚 ಕನ್ನಡ ಅನುವಾದ ಪುಸ್ತಕಗಳ ಜಗತ್ತು")
  heroTitle       String   @default("ಸೃಷ್ಟಿ ಪಬ್ಲಿಕೇಷನ್ಸ್")
  heroDescription String   @db.Text
  heroButtonText  String   @default("ಪುಸ್ತಕಗಳನ್ನು ಅನ್ವೇಷಿಸಿ")
  heroImage       String?
  statsBooks      String   @default("200+")
  statsAuthors    String   @default("50+")
  statsCustomers  String   @default("5000+")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// ADMIN USERS (with password hashing)
// ============================================

model AdminUser {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String   // bcrypt hashed password
  name          String?
  role          String   @default("admin") // 'superadmin', 'admin', 'editor'
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================
// CUSTOMER ACCOUNTS
// ============================================

model Customer {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?  // null for guest-converted accounts that haven't set password
  name          String
  phone         String?
  
  // Default shipping address
  address       String?
  city          String?
  state         String?  @default("Karnataka")
  pincode       String?
  
  // Account status
  isVerified    Boolean  @default(false)
  verifyToken   String?
  resetToken    String?
  resetTokenExp DateTime?
  
  // Preferences
  receiveEmails Boolean  @default(true)
  
  // Relations
  orders        Order[]  @relation("CustomerOrders")
  
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([email])
  @@index([phone])
}

// ============================================
// FULL SITE SETTINGS (stored in DB)
// ============================================

model SiteSettingsV2 {
  id                    String   @id @default(cuid())
  
  // Hero Section
  heroTagline           String   @default("📚 ಕನ್ನಡ ಅನುವಾದ ಪುಸ್ತಕಗಳ ಜಗತ್ತು")
  heroTitle             String   @default("ಸೃಷ್ಟಿ ಪಬ್ಲಿಕೇಷನ್ಸ್")
  heroDescription       String   @db.Text
  heroButtonText        String   @default("ಪುಸ್ತಕಗಳನ್ನು ಅನ್ವೇಷಿಸಿ")
  
  // Stats
  statsBooks            String   @default("200+")
  statsAuthors          String   @default("50+")
  statsCustomers        String   @default("5000+")
  
  // Sale Timer
  saleTimerEnabled      Boolean  @default(false)
  saleTimerTitle        String?
  saleTimerEndDate      DateTime?
  saleTimerDiscountText String?
  
  // Social Proof
  socialProofEnabled    Boolean  @default(true)
  socialProofInterval   Int      @default(15000)
  
  // Contact
  whatsappNumber        String   @default("919845096668")
  whatsappMessage       String   @default("ನಮಸ್ಕಾರ, ನನಗೆ ಪುಸ್ತಕಗಳ ಬಗ್ಗೆ ಮಾಹಿತಿ ಬೇಕು.")
  
  // Footer
  footerDescription     String?
  copyrightText         String?
  
  // SEO
  siteTitle             String?
  siteDescription       String?
  siteKeywords          String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
